{
  "$schema": "./extgen.schema.json",
  "input": "spec.gmidl",
  "root": "./",
  "gamemaker": {
    "wrappers": {
      "outputFile": "../../../scripts/PlayAgeSignals_API/PlayAgeSignals_API.gml"
    },
    "extension": {
      "mode": "patch",
      "outputFile": "../../../extensions/PlayAgeSignals/PlayAgeSignals.yy"
    },
    "injectors": { }
  },
    "targets": {
        "sourceFolder": "./native",
        "sourceFile": "{0}_native",
        "android": {"mode": "java"}
    },
  "extras": {
    "docs": { 
      "outputFile": "../../../../../docs/extgen_docs.js"
    }
  },
    "build": {
        "emitCmake": true,
        "cmake": {
            "cppStandard": 17,
            "cppExtensions": false,
            "strictWarnings": true,
            "useThirdParty": true,
            "emitPresets": true
        }
    }
}